\newcommand{\cabecalhoCurso}[6]{
\hbadness=10000
\noindent%
\begin{center}%
  \fbox{%
  \begin{minipage}{.98\textwidth}%
    \begin{tabular*}{\linewidth}{@{} l p{9.1cm} R{6cm}@{}}
      \multirow{2}{*}{\scalebox{.20}{\tikz \pic{ifsclogo={black}{black}};}} & {\small #1} &  {\small #3} \\% 
      &  {\small #2} &  {\small #4}%
    \end{tabular*}
    \begin{center}%
      #5
    \end{center}%
    \begin{flushright}
      {\small #6}
    \end{flushright}
  \end{minipage}%
  }%
\end{center}%
\bigskip%
}
