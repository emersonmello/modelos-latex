% -------------------------------------------------%
% Ambientes inspirados nos estilos de alertas do Markdown do GitHub
% -------------------------------------------------%

\tcbset{alertmarkdown/.style={%
  arc=0mm, % arredondamento dos cantos
  boxrule=0mm, % espessura da borda
  leftrule=1mm, % espessura da barra lateral
  left=2mm, % espaçamento entre a barra lateral e o conteúdo
  top=1mm, % espaçamento superior
  parbox=false, % para evitar que o conteúdo seja colocado dentro de uma caixa de parágrafo
  enhanced, % para permitir o uso de recursos avançados do tcolorbox
  opacityback=0, % transparência do fundo
  opacitybacktitle=0, % transparência do título
  opacityframe=0 % transparência da borda
  }
}

