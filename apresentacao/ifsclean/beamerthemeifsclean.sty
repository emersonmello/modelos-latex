\ProcessKeyvalOptions*

% -------------------------------------------------%
% Configuracoes dos pacotes
% -------------------------------------------------%

% Configuracoes para o pacote siunitx
\sisetup{
  locale = DE, % Configura o pacote para usar a vírgula como separador decimal
  output-decimal-marker = {,}, % Define a vírgula como separador decimal na saída
  group-separator = {.}, % Define o ponto como separador de milhares
  group-minimum-digits = 4, % Define o número mínimo de dígitos para usar o separador de milhares
  per-mode = symbol, % Define o formato para unidades por outra unidade (e.g. m/s)
  detect-all % Detecta o modo matemático ou texto para formatar as unidades de acordo
}

% Para diminuir o tamanho da fonte do caption da figura
% \captionsetup[figure]{font=tiny}

\hypersetup{pdffitwindow=false, pdfstartview={FitW},colorlinks=false}

% Aumentando a altura das linhas nas tabelas
\renewcommand{\arraystretch}{1.2}

% Aumentando a altura das linhas
\linespread{1.05}


% ---------------------------------------
% Settings
% ---------------------------------------
\usefonttheme{ifsclean}
\usecolortheme{ifsclean}
\useinnertheme{ifsclean}
\useoutertheme{ifsclean}
\setbeamertemplate{navigation symbols}{}

% ---------------------------------------
\mode<all>
% ---------------------------------------

% Novos tipos de colunas alinhado: a direita, centralizado ou esquerda e que permita definir a largura
% pacote ragged2e para usar \RaggedRight, \RaggedLeft e \centering
\newcolumntype{R}[1]{>{\RaggedLeft\arraybackslash}p{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}p{#1}}
\newcolumntype{L}[1]{>{\RaggedRight\arraybackslash}p{#1}}
% ---------------------------------------

% Use esse comando para fazer links para sites
\newcommand{\Myhref}[3][azul]{\href{#2}{\color{#1}{#3}}}%

% Comando para incluir um assunto no slide de título
\def\beamerthemeifsclean@subject{}
\renewcommand{\subject}[1]{%
  \def\beamerthemeifsclean@subject{#1}%
  \hypersetup{pdfsubject={#1}}%
}
\newcommand{\insertsubject}{\beamerthemeifsclean@subject}

