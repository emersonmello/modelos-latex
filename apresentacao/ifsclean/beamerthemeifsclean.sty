% ---------------------------------------
% Baloes de informacao
% ---------------------------------------
\newtcolorbox[auto counter,number within=section]{caixainfo}[3][]{%
  enhanced,
  colback=#1,colframe=#1,
  fontupper=\color{#2},
  leftrule=15mm,
  underlay unbroken and first={%
    \node[below,text=#2,anchor=east]
      at ([xshift=0mm]interior.base west) {\huge  #3};
  }
}

\newenvironmentx{caixa}[3][1=verde]
{
\usebeamercolor[fg]{item caixa}%
\setbeamercolor{structure}{bg=bg,fg=white}
\setbeamercolor{item projected}{fg=black,bg=white} 
\begin{caixainfo}[#1]{#2}{#3}}{\end{caixainfo}}

\newenvironmentx{informacao}[3][1=verde,2=white,3=\faCircleInfo]
{\begin{caixa}[#1]{#2}{#3}}{\end{caixa}}

\newenvironmentx{informacaoazul}[3][1=azul,2=white,3=\faCircleInfo]
{\begin{caixa}[#1]{#2}{#3}}{\end{caixa}}

\newenvironmentx{atencao}[3][1=amarelo,2=black,3=\faTriangleExclamation]
{\begin{caixa}[#1]{#2}{#3}\usebeamercolor[fg]{item caixaclara}
}{\end{caixa}}

\newenvironmentx{cuidado}[3][1=vermelho,2=white,3=\faCircleExclamation]
{\begin{caixa}[#1]{#2}{#3}}{\end{caixa}}


% -------------------------------------------------%
% Ambientes inspirados nos estilos de alertas do Markdown do GitHub
% -------------------------------------------------%
\definecolor{notecolor}{RGB}{9,105,218}
\definecolor{tipcolor}{RGB}{26,127,25}
\definecolor{importantcolor}{RGB}{130,80,223}
\definecolor{warningcolor}{RGB}{253,165,15}
\definecolor{cautioncolor}{RGB}{207,34,46}

\tcbset{alertmarkdown/.style={%
arc=0mm,boxrule=0mm,leftrule=1mm,left=2mm,top=1mm,parbox=false,enhanced,opacityback=1,opacitybacktitle=1,opacityframe=0}}

\newtcolorbox{nota}{alertmarkdown,colback=notecolor!5!white,colbacktitle=notecolor!5!white,borderline west={3pt}{0pt}{notecolor},coltitle=notecolor,title={\faCircleInfo~~\textbf{Nota}}}

\newtcolorbox{tip}{alertmarkdown,colback=tipcolor!5!white,colbacktitle=tipcolor!5!white,borderline west={3pt}{0pt}{tipcolor},coltitle=tipcolor,title={\faLightbulb[regular]~~\textbf{Dica}}}

\newtcolorbox{important}{alertmarkdown,colback=importantcolor!5!white,colbacktitle=importantcolor!5!white,borderline west={3pt}{0pt}{importantcolor},coltitle=importantcolor,title={\faExclamation~~\textbf{Importante}}}

\newtcolorbox{warning}{alertmarkdown,colback=warningcolor!5!white,colbacktitle=warningcolor!5!white,borderline west={3pt}{0pt}{warningcolor},coltitle=warningcolor,title={\faTriangleExclamation~~\textbf{Atenção}}}

\newtcolorbox{caution}{alertmarkdown,colback=cautioncolor!5!white,colbacktitle=cautioncolor!5!white,borderline west={3pt}{0pt}{cautioncolor},coltitle=cautioncolor,title={\faCircleExclamation~~\textbf{Cuidado}}}

