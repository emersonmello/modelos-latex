% Escolha de fontes
% -------------------------------------------------%
\ifPDFTeX
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
  \RequirePackage{textcomp}
  \RequirePackage{gensymb}

\else
% Se o usuario estiver usando o LuaLaTeX ou o XeLaTeX, use o fontspec para carregar as fontes do sistema. 
  \RequirePackage{fontspec}
  \RequirePackage{unicode-math}
  \usefonttheme{professionalfonts}
  \defaultfontfeatures{Ligatures=TeX,Scale=MatchLowercase,Renderer=HarfBuzz}
  
  \IfFontExistsTF{Inconsolata}{
    \setmonofont[
      % UprightFont    = * Regular,
      % BoldFont       = * Bold,
      ItalicFont     = * Regular,
      BoldItalicFont = * Bold,
      Scale          = 0.85, %MatchLowercase,
      Ligatures      = NoCommon,
      RawFeature     = {wght=300}, % Força a versão light da Inconsolata, que é mais legível em slides
    ]{Inconsolata}
  }{
    \setmonofont{TeX Gyre Cursor}
  }

  \IfFontExistsTF{Inter}{
    \setsansfont[
      UprightFont = * Light,
      BoldFont = * Bold,
      ItalicFont = * Light Italic,
      BoldItalicFont = * Bold Italic,
    ]{Inter}
  }{
    \setsansfont{TeX Gyre Heros}
  }

  % \IfFontExistsTF{Fira Math}{
  %     \setmathfont{Fira Math}[Scale=MatchLowercase]
  % }{}
  % \setmathfont{TeX Gyre Termes Math}[Scale=MatchLowercase]
\fi



